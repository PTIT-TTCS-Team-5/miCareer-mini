# Database (Chung với FANG / miCareer-lite)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/micareer_lite_db

# FANG AI Core endpoint — miCareer-mini gọi tất cả AI qua đây
FANG_API_URL=http://localhost:8000/v2

# Cloudinary — upload CV PDF (lấy từ https://console.cloudinary.com/settings/api-keys)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App config
LOG_LEVEL=INFO
